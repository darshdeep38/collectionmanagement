// method for partial payment history

@AuraEnabled(cacheable=true)
public static List<CollectibleHistoryWrapper> getPartialPaymentHistory(Id milestoneId) {

    List<CollectibleHistoryWrapper> result =
        new List<CollectibleHistoryWrapper>();

    for (builderopedia__Payment_Milestone__History  h : [
        SELECT OldValue,
               NewValue,
               CreatedDate,
               CreatedBy.Name
        FROM builderopedia__Payment_Milestone__History 
        WHERE ParentId = :milestoneId
        AND Field = 'Partial_Payment_Amount__c'
        ORDER BY CreatedDate DESC
    ]) {

        CollectibleHistoryWrapper row =
            new CollectibleHistoryWrapper();

        row.oldValue = String.valueOf(h.OldValue);
        row.newValue = String.valueOf(h.NewValue);
        row.changedBy = h.CreatedBy.Name;
        row.changedDate = h.CreatedDate;

        result.add(row);
    }

    return result;
}






// Send SOA Email
@AuraEnabled
public static String sendSOAEmail(Id bookingId) {

    try {

        // Get Booking + Bill To Applicant Email
        builderopedia__Booking__c bookingRec = [
            SELECT Id,
                   Name,
                   builderopedia__Bill_To_Applicant__r.builderopedia__Email__c,
                   builderopedia__Bill_To_Applicant__r.Name
            FROM builderopedia__Booking__c
            WHERE Id = :bookingId
            LIMIT 1
        ];

        if(String.isBlank(
            bookingRec.builderopedia__Bill_To_Applicant__r.builderopedia__Email__c
        )){
            throw new AuraHandledException(
                'Bill To Applicant Email is missing.'
            );
        }

        // Reuse existing SOA fetch logic
        CustomerSOAAPIHandler.SOAResponseWrapper response =
            CustomerSOAAPIHandler.handleCustomerSOARequest(
                bookingId,
                'Statement_of_Account'
            );

        if(response == null || response.status != 'success'){
            throw new AuraHandledException(
                response != null
                ? response.response
                : 'Unable to fetch SOA document.'
            );
        }

        // Create PDF attachment
        Messaging.EmailFileAttachment attachment =
            new Messaging.EmailFileAttachment();

        attachment.setFileName(response.fileName);
        attachment.setBody(
            EncodingUtil.base64Decode(response.base64Pdf)
        );
        attachment.setContentType('application/pdf');

        // Email
        Messaging.SingleEmailMessage mail =
            new Messaging.SingleEmailMessage();

        mail.setToAddresses(
            new List<String>{
                bookingRec.builderopedia__Bill_To_Applicant__r.builderopedia__Email__c
            }
        );

        mail.setSubject('Statement Of Account');

        mail.setHtmlBody(
            'Dear Customer,<br/><br/>' +
            'Please find attached your latest Statement of Account.<br/><br/>' +
            'Regards,<br/>' +
            'Collections Team'
        );

        mail.setFileAttachments(
            new Messaging.EmailFileAttachment[]{
                attachment
            }
        );

        Messaging.sendEmail(
            new Messaging.SingleEmailMessage[]{
                mail
            }
        );

        return 'Email sent successfully';

    } catch(Exception e){

        throw new AuraHandledException(
            e.getMessage()
        );

    }
}







    @AuraEnabled
    public static TPRCaseResult createTPRCase(Id demandId , Decimal earlierDays , Decimal requestedAmount) {


        Decimal reqAmt = requestedAmount != null
    ? requestedAmount
    : 0;

        try {
            List<builderopedia__Demand__c> demandList = [
                SELECT Id,
                       Name,
                       builderopedia__Booking__c,
                       builderopedia__Booking__r.builderopedia__Project__c,
                       builderopedia__Booking__r.builderopedia__Bill_To_Applicant__c,
                        builderopedia__Payment_Milestone__c
                FROM   builderopedia__Demand__c
                WHERE  Id = :demandId
                LIMIT 1
            ];

            //if (demandList.isEmpty()) {
             //   throw new AuraHandledException('Demand record not found. Id: ' + demandId);
            //}

if (demandList.isEmpty()) {

    builderopedia__Payment_Milestone__c milestoneRec = [
        SELECT Id,
               Name,
               builderopedia__Booking__c,
               builderopedia__Booking__r.builderopedia__Project__c,
               builderopedia__Booking__r.builderopedia__Bill_To_Applicant__c
        FROM builderopedia__Payment_Milestone__c
        WHERE Id = :demandId
        LIMIT 1
    ];

    String expectedSubject = 'TPR Case - ' + milestoneRec.Name;

    List<Case> existingCases = [
        SELECT Id, CaseNumber, Status
        FROM Case
        WHERE builderopedia__Booking__c = :milestoneRec.builderopedia__Booking__c
        AND Case_Type__c = 'TPR'
        AND Subject = :expectedSubject
        LIMIT 1
    ];

    if (!existingCases.isEmpty()) {
        throw new AuraHandledException(
            'TPR Case is already created. Case # ' +
            existingCases[0].CaseNumber
        );
    }

    List<RecordType> rtList = [
        SELECT Id
        FROM RecordType
        WHERE SObjectType = 'Case'
        AND Name = 'Customer Service'
        LIMIT 1
    ];

    Case newCase = new Case(
        Status               = 'Open',
        Subject              = expectedSubject,
        Origin               = 'Others',
        Process_Type__c      = 'TPR',
        Case_Type__c         = 'TPR',
        Case_Sub_Type__c     = 'TPR',
        Case_Sub_Sub_Type__c = 'Others',
        builderopedia__Booking__c = milestoneRec.builderopedia__Booking__c,
        builderopedia__Project__c = milestoneRec.builderopedia__Booking__r.builderopedia__Project__c,
        Applicant__c              = milestoneRec.builderopedia__Booking__r.builderopedia__Bill_To_Applicant__c,
        Description               = 'Auto-created from Collection screen',
        Earlier_Days__c = earlierDays,
        Payment_Milestone__c      = milestoneRec.Id,
        Requested_Amount__c  = reqAmt
    );

    if (!rtList.isEmpty()) {
        newCase.RecordTypeId = rtList[0].Id;
    }

    insert newCase;

    Case inserted = [
        SELECT Id, CaseNumber
        FROM Case
        WHERE Id = :newCase.Id
        LIMIT 1
    ];

    return new TPRCaseResult(
        inserted.Id,
        inserted.CaseNumber
    );
}



            builderopedia__Demand__c demandRec = demandList[0];
            String expectedSubject = 'TPR Case - ' + demandRec.Name;
            List<Case> existingCases = [
                SELECT Id, CaseNumber, Status
                FROM   Case
                WHERE  builderopedia__Booking__c = :demandRec.builderopedia__Booking__c
                AND    Case_Type__c              = 'TPR'
                AND    Subject                   = :expectedSubject
                LIMIT 1
            ];

            if (!existingCases.isEmpty()) {
                throw new AuraHandledException(
                    'TPR Case is already created. Case # ' + existingCases[0].CaseNumber
                );
            }



            List<RecordType> rtList = [
                SELECT Id
                FROM   RecordType
                WHERE  SObjectType = 'Case'
                AND    Name        = 'Customer Service'
                LIMIT 1
            ];

            Case newCase = new Case(
                Status               = 'Open',
                Subject              = expectedSubject,
                Origin               = 'Others',
                Process_Type__c      = 'TPR',
                Case_Type__c         = 'TPR',
                Case_Sub_Type__c     = 'TPR',
                Case_Sub_Sub_Type__c = 'Others',
                builderopedia__Booking__c = demandRec.builderopedia__Booking__c,
                builderopedia__Project__c = demandRec.builderopedia__Booking__r.builderopedia__Project__c,
                Applicant__c              = demandRec.builderopedia__Booking__r.builderopedia__Bill_To_Applicant__c,
                Description               = 'Auto-created from Collection screen',
                Earlier_Days__c           = earlierDays,
                Payment_Milestone__c      = demandRec.builderopedia__Payment_Milestone__c,
                Requested_Amount__c       = reqAmt
            );

            if (!rtList.isEmpty()) {
                newCase.RecordTypeId = rtList[0].Id;
            }

            insert newCase;
            Case inserted = [SELECT Id, CaseNumber FROM Case WHERE Id = :newCase.Id LIMIT 1];

            System.debug('Created Case Id = ' + inserted.Id + ', Number = ' + inserted.CaseNumber);

            return new TPRCaseResult(inserted.Id, inserted.CaseNumber);

        } catch (AuraHandledException ahe) {
            throw ahe;
        } catch (Exception e) {
            System.debug('TPR CASE ERROR => ' + e.getMessage());
            System.debug('TPR CASE STACK => ' + e.getStackTraceString());
            throw new AuraHandledException('Error creating TPR Case: ' + e.getMessage());
        }
    }


@AuraEnabled
public static String sendDemandEmail(Id demandId)
{
    try
    {
        Map<String,Object> flowInputs = new Map<String,Object>();
        flowInputs.put('varDemandId', demandId);

        Flow.Interview.Send_Demand_Email flowObj =
            new Flow.Interview.Send_Demand_Email(flowInputs);

        flowObj.start();

        return 'Demand email sent successfully.';
    }
    catch(Exception e)
    {
        throw new AuraHandledException(
            'Error sending email: ' + e.getMessage()
        );
    }
}


